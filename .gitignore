# EEG pipeline derivatives (checkpoints, not source)
derivatives/
*.set
*.fdt
*.bdf
*.edf
*.mat

# Allow-list: track small QA artifacts under derivatives/ (figures, csv,
# params) so 3-subject results survive repo moves; heavy .set/.fdt files
# stay ignored via the extension-based rules above.
!derivatives/
!derivatives/**/
!derivatives/**/*.png
!derivatives/**/qa_*.csv
!derivatives/**/params.json
!derivatives/**/README.md

# MATLAB scratch
*.asv
*.m~
slprj/
codegen/

# macOS / editor
.DS_Store
.vscode/
.idea/

# Python helpers (if added)
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.ty_cache/

# Secrets / local config
.env
.env.*
!.env.example
*.local

# .claude/ is tracked so collaborators see project agents, commands,
# and epic-dev state. Only the per-user permission file is private.
.claude/settings.local.json
